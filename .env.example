# ─── Supabase ────────────────────────────────────────────────────────────────
# Disponible dans : Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Discord ─────────────────────────────────────────────────────────────────
# Paramètres du channel → Intégrations → Webhooks → Copier l'URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXXXXXX

# Mentions Discord pour les assignations (optionnel — utiliser <@USER_ID> pour un vrai ping)
# Exemple : DISCORD_MENTION_JEREMY=<@123456789012345678>
DISCORD_MENTION_JEREMY=@vitaly
DISCORD_MENTION_TATIANA=@tatiana

# ─── Auth ────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Générer avec : openssl rand -hex 32
ICAL_SECRET=your-ical-token-for-calendar-subscription

# Utilisateurs — hasher les mots de passe avec :
#   node -e "const b = require('bcryptjs'); b.hash('mot-de-passe', 10).then(console.log)"
USERS_CONFIG=[{"username":"Alice","password":"$2a$10$..."},{"username":"Bob","password":"$2a$10$..."},{"username":"Charlie","password":"$2a$10$..."}]
