# ─── Supabase ────────────────────────────────────────────────────────────────
# Disponible dans : Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Discord ─────────────────────────────────────────────────────────────────
# Paramètres du channel → Intégrations → Webhooks → Copier l'URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXXXXXX

# ─── Auth ────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Générer avec : openssl rand -hex 32
ICAL_SECRET=your-ical-token-for-calendar-subscription

# Utilisateurs — hasher les mots de passe avec :
#   node -e "const b = require('bcryptjs'); b.hash('mot-de-passe', 10).then(console.log)"
USERS_CONFIG=[{"username":"Alice","password":"$2a$10$..."},{"username":"Bob","password":"$2a$10$..."},{"username":"Charlie","password":"$2a$10$..."}]
